{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "import"],
  "categories": {
    "correctness": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "off",
    "no-debugger": "warn"
  },
  "env": {
    "browser": true
  },
  "ignorePatterns": ["dist", "node_modules", ".*/**"]
}
